{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "frontend/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "frontend/dashboard/$1"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "frontend/dashboard/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dashboard/login.html"
    }
  ]
}