{
  "version": 2,
  "buildCommand": "echo 'Build: No build command needed'",
  "outputDirectory": ".",
  "runtimeVersion": "3.11.9",
  "pythonVersion": "3.11",
  "functions": {
    "backend/app.py": {
      "runtime": "python3.11",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "backend/**",
      "excludeFiles": "tests/**"
    }
  },
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python@4.5.0",
      "config": {
        "runtime": "python3.11",
        "pythonVersion": "3.11.9"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "frontend/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "frontend/dashboard/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "frontend/dashboard/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dashboard/login.html"
    }
  ],
  "env": {
    "FLASK_ENV": "@vercel_flask_env",
    "ENVIRONMENT": "@vercel_environment",
    "LOG_LEVEL": "@vercel_log_level"
  }
}

