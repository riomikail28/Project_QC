{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/dashboard/:path*"
    },
    {
      "source": "/skills/:path*",
      "destination": "/skills/:path*"
    },
    {
      "source": "/landing.html",
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "destination": "/main.py"
    }
  ]
}