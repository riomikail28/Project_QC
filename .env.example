# Flask / Vercel
FLASK_ENV=production
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ISSUER=qc-traceability-api
JWT_ACCESS_TOKEN_MINUTES=480
REFRESH_TOKEN_DAYS=14
REFRESH_TOKEN_COOKIE=refresh_token
CORS_ORIGINS=https://project-qc-mu.vercel.app/
MAX_REQUEST_BYTES=10485760
MAX_UPLOAD_BYTES=10485760
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
ALERT_WEBHOOK_URL=
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=YOUR_GOOGLE_APPS_SCRIPT_WEBHOOK_URL

# Supabase
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=qc-evidence

# Optional database / integrations
DATABASE_URL=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# GitHub Actions / Vercel secrets
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_TOKEN=your-vercel-token
