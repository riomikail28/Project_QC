# ============================================================
# QC Central Kitchen — Environment Variables
# ============================================================
# WARNING: Never commit real credentials to version control.
# Copy this file to .env and fill in your actual values.
# The .env file is excluded via .gitignore.
# ============================================================

# Flask / Vercel
FLASK_ENV=production
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ISSUER=qc-traceability-api
JWT_ACCESS_TOKEN_MINUTES=480
REFRESH_TOKEN_DAYS=14
REFRESH_TOKEN_COOKIE=refresh_token
CORS_ORIGINS=https://your-project.vercel.app
MAX_REQUEST_BYTES=10485760
MAX_UPLOAD_BYTES=10485760
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
ALERT_WEBHOOK_URL=
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=qc-evidence

# Optional database / integrations
DATABASE_URL=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# GitHub Actions / Vercel secrets
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_TOKEN=your-vercel-token
